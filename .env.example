# Copy to `.env` on the VPS (optional) or set these as Windows System Environment Variables.
# Values here are EXAMPLES — use your real MT5 demo password from HFM, not VPS RDP password.

# MetaTrader 5 — trading password (from HFM client area / MT5 credentials).
AI_TRADER_MT5_PASSWORD=

# Optional: full path to MetaTrader 5 terminal executable on Windows, e.g.
# C:\Program Files\MetaTrader 5\terminal64.exe
# AI_TRADER_MT5_TERMINAL_PATH=

# Optional: override login if you prefer not to put account number in YAML.
# AI_TRADER_MT5_LOGIN=
